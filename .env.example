# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Webhook secret (set when registering webhook with Telegram)
WEBHOOK_SECRET=your_webhook_secret_here

# Supabase (avatar-sdk project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# community-admin config seam (optional). When both are set, group config is read
# from community-admin's GET /api/config (60s cache); otherwise groups.json is used.
CA_CONFIG_URL=https://community-admin-server-production.up.railway.app/api/config
CA_CONFIG_SECRET=shared_secret_matching_community_admin

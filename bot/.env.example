# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Group ID to monitor (use /debug command in group to find this)
MONITOR_GROUP_ID=

# Topic IDs to monitor (use /debug command in each topic to find these)
TOPIC_LINKS_ID=
TOPIC_MEMES_ID=

# Channel to post digests (default: @scenius)
DIGEST_CHANNEL_ID=-1002708526104

# Schedule: day of week (0=Monday, 6=Sunday) and hour (UTC)
DIGEST_DAY=0
DIGEST_HOUR=9
